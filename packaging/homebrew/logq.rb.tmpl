# Homebrew formula template — values are substituted from a GitHub release
# by scripts/update-homebrew.sh. Drop the rendered file into a tap repo
# (e.g. alldoq/homebrew-tap) as Formula/logq.rb.
class Logq < Formula
  desc "Local-first JSONL log explorer powered by DuckDB"
  homepage "https://alldoq.github.io/logq/"
  version "__VERSION__"
  license "MIT OR Apache-2.0"

  on_macos do
    on_arm do
      url "https://github.com/alldoq/logq/releases/download/v__VERSION__/logq-v__VERSION__-aarch64-apple-darwin.tar.gz"
      sha256 "__SHA_DARWIN_ARM__"
    end
    on_intel do
      url "https://github.com/alldoq/logq/releases/download/v__VERSION__/logq-v__VERSION__-x86_64-apple-darwin.tar.gz"
      sha256 "__SHA_DARWIN_X86__"
    end
  end

  on_linux do
    on_arm do
      url "https://github.com/alldoq/logq/releases/download/v__VERSION__/logq-v__VERSION__-aarch64-unknown-linux-gnu.tar.gz"
      sha256 "__SHA_LINUX_ARM__"
    end
    on_intel do
      url "https://github.com/alldoq/logq/releases/download/v__VERSION__/logq-v__VERSION__-x86_64-unknown-linux-gnu.tar.gz"
      sha256 "__SHA_LINUX_X86__"
    end
  end

  def install
    bin.install "logq"
  end

  test do
    assert_match version.to_s, shell_output("#{bin}/logq --version")
  end
end
